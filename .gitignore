# Unity .gitignore

# Library and build cache
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/

# MemoryCaptures
[Mm]emoryCaptures/

# Recordings
[Rr]ecordings/

# Asset meta data should be tracked with git-lfs
# But still ignore certain generated files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity3D generated meta files
*.pidb
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity3D generated file on crash reports
sysinfo.txt

# Builds
*.apk
*.aab
*.unitypackage
*.app

# Crashlytics generated file
crashlytics-build.properties

# Visual Studio / JetBrains
.vs/
.idea/
*.DotSettings.user
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln

# macOS
.DS_Store
*.swp
*.lock
profile

# Windows
Thumbs.db
Desktop.ini

# Gradle (if Android build)
.gradle/

# TextMeshPro
Assets/TextMesh*Pro/

# Packaging output
Releases/
PackagedBuilds/

# Environment / secrets
.env
*.env.local

# Ollama / AI model cache (don't commit models)
Models/
*.gguf
*.bin
